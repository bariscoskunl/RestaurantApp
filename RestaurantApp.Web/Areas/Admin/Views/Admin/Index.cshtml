@model IEnumerable<RestaurantApp.Common.Models.Product>
@*admin index dashboard*@

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin Panel</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="~/css/admin.css" rel="stylesheet">
    </head>
    <body>
        <div class="container-fluid">
            <div class="row">
                <!-- Sidebar -->
            @await Component.InvokeAsync("AdminSidebar")

                <!-- Main content -->
                <main class="col-md-9 ms-sm-auto col-lg-10 px-md-4">
                    <div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom">
                        <h1 class="h2">Admin Paneli</h1>
                    </div>

                    <div class="d-flex align-items-center mb-3">
                        <h2 class="mb-0">Ürünler</h2>
                        
                        <div class="ms-4 d-flex align-items-center">
                            <label for="categoryFilter" class="me-2 fw-bold">Kategoriye Göre Filtrele:</label>
                            <select id="categoryFilter" class="form-select w-auto">
                                <option value="all">Tüm Kategoriler</option>
                            </select>
                        </div>

                        <a asp-area="Admin" asp-controller="Admin" asp-action="CreateProduct" class="btn btn-primary ms-auto">Ürün Ekle</a>
                    </div>
                    <div class="table-responsive">
                        <table class="table table-striped table-sm">
                            <thead class="table-dark">
                                <tr>
                                    <th>Ürün Adı</th>
                                    <th>Fiyat</th>
                                    <th>Açıklama</th>
                                    <th>İçindekiler</th>
                                    <th>Kategori</th>
                                    <th>Görsel</th>
                                    <th>İşlemler</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var product in Model)
                                {
                                    <tr class="product-row" data-category="@(product.Category?.Name ?? "Uncategorized")">
                                        <td>@product.Name</td>
                                        <td>@product.Price ₺</td>
                                        <td>@product.Description</td>
                                        <td>@product.Ingredients</td>
                                        <td class="category-name">@(product.Category?.Name ?? "-")</td>
                                        <td><img src="~/images/@product.ImageUrl" alt="Product Image" width="50" height="50" /></td>
                                        <td>
                                            <div class="d-flex gap-2">
                                                <a asp-area="Admin" asp-controller="Admin" asp-action="EditProduct" asp-route-id="@product.Id" class="btn btn-sm btn-warning">Düzenle</a>
                                                <a asp-area="Admin" asp-controller="Admin" asp-action="DeleteProduct" asp-route-id="@product.Id" class="btn btn-sm btn-danger">Sil</a>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </main>
            </div>
        </div>

        <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
        <script src="~/js/admin.js"></script>
        <script>
            document.addEventListener('DOMContentLoaded', function() {
                const categorySelect = document.getElementById('categoryFilter');
                const productRows = document.querySelectorAll('.product-row');
                
                // Extract unique categories from rows
                const categories = new Set();
                document.querySelectorAll('.category-name').forEach(td => {
                    const catName = td.textContent.trim();
                    if(catName !== '-') {
                        categories.add(catName);
                    }
                });

                // Populate select
                categories.forEach(cat => {
                    const option = document.createElement('option');
                    option.value = cat;
                    option.textContent = cat;
                    categorySelect.appendChild(option);
                });

                // Filter logic
                categorySelect.addEventListener('change', function() {
                    const selectedCat = this.value;
                    productRows.forEach(row => {
                        if (selectedCat === 'all' || row.dataset.category === selectedCat) {
                            row.style.display = '';
                        } else {
                            row.style.display = 'none';
                        }
                    });
                });
            });
        </script>
    </body>
</html>

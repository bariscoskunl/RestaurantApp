@model RestaurantApp.Common.Models.Category

<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Kategori Sil - Admin Panel</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="~/css/admin.css" rel="stylesheet">
</head>
<body>
    <div class="container-fluid">
        <div class="row">

            @await Component.InvokeAsync("AdminSidebar")

            <main class="col-md-9 ms-sm-auto col-lg-10 px-md-4">
                <div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom">
                    <h1 class="h2 text-danger">Kategori Sil</h1>
                </div>

                <div class="alert alert-danger" role="alert">
                    <h4 class="alert-heading">Dikkat!</h4>
                    <p><strong>@Model.Name</strong> kategorisini silmek üzeresiniz. Bu işlem geri alınamaz.</p>
                    <hr>
                    <p class="mb-0">Eğer bu kategoriye ait ürünler varsa, veritabanı kurallarına göre silme işlemi hata verebilir veya o ürünler kategorisiz kalabilir. Devam etmek istediğinize emin misiniz?</p>
                </div>

                <form asp-controller="Admin" asp-action="DeleteCategory" method="post">
                    <input type="hidden" asp-for="Id" />
                    <button type="submit" class="btn btn-danger">Evet, Kategoriyi Sil</button>
                    <a asp-area="Admin" asp-controller="Admin" asp-action="Categories" class="btn btn-secondary ms-2">İptal</a>
                </form>
            </main>
        </div>
    </div>

    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>

@model RestaurantApp.Common.Models.Category

<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Kategori Ekle - Admin Panel</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="~/css/admin.css" rel="stylesheet">
</head>
<body>
    <div class="container-fluid">
        <div class="row">
            @await Component.InvokeAsync("AdminSidebar")

            <main class="col-md-9 ms-sm-auto col-lg-10 px-md-4">
                <div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom">
                    <h1 class="h2">Yeni Kategori Ekle</h1>
                </div>

                <div class="row">
                    <div class="col-md-6">
                        <form action="/Admin/Admin/CreateCategory" method="post">
                            @Html.AntiForgeryToken()
                            <div asp-validation-summary="All" class="text-danger"></div>
                            
                            <div class="mb-3">
                                <label asp-for="Name" class="form-label fw-bold">Kategori Adı :</label>
                                <input asp-for="Name" class="form-control" type="text" placeholder="Örn: Burgerler" required />
                                <span asp-validation-for="Name" class="text-danger"></span>
                            </div>
                            
                            <div class="mb-3">
                                <label asp-for="IsInStock" class="form-label fw-bold">Stokta Var Mı?</label>
                                <select asp-for="IsInStock" class="form-select">
                                    <option value="true">Evet, Stokta Var</option>
                                    <option value="false">Hayır, Stokta Yok</option>
                                </select>
                            </div>
                            
                            <div class="mb-4 bg-light p-3 border rounded">
                                <label asp-for="IsMenuCategory" class="form-label fw-bold text-warning" style="text-shadow: 0px 0px 1px #000;">
                                    Bu bir Menü Kategorisi mi?
                                </label>
                                <select asp-for="IsMenuCategory" class="form-select border-warning">
                                    <option value="true">Evet, bu bir Menü Kategorisidir</option>
                                    <option value="false" selected>Hayır, normal bir kategoridir</option>
                                </select>
                                <small class="d-block text-muted mt-2">Eğer "Evet" derseniz, bu kategori anasayfadaki "Menüler" sekmesinde yer alacaktır. (Örn: Ekonomik Menüler, Fix Menüler vb.)</small>
                            </div>
                            
                            <button type="submit" class="btn btn-success">Kaydet</button>
                            <a href="/Admin/Admin/Categories" class="btn btn-secondary ms-2">Geri Dön</a>
                        </form>
                    </div>
                </div>
            </main>
        </div>
    </div>

    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>

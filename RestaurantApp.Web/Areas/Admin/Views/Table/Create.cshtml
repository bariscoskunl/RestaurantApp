<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin Panel - Yeni Masa Ekle</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="~/css/admin.css" rel="stylesheet">
    <style>
        .create-form-card {
            max-width: 500px;
            margin: 0 auto;
            background: #fff;
            border-radius: 16px;
            padding: 2rem 1.5rem;
            box-shadow: 0 4px 16px rgba(0,0,0,0.08);
        }
        .create-form-card h3 {
            font-weight: 700;
            margin-bottom: 1.5rem;
        }
        .btn-save {
            border-radius: 10px;
            font-weight: 600;
            padding: 0.65rem;
            font-size: 1rem;
        }
        .btn-back {
            border-radius: 10px;
            font-weight: 600;
            padding: 0.65rem;
            font-size: 1rem;
        }

        @@media (max-width: 767.98px) {
            #sidebar {
                display: none !important;
            }
            main {
                margin-left: 0 !important;
                padding: 0.75rem !important;
            }
            .create-form-card {
                padding: 1.5rem 1rem;
            }
        }
    </style>
</head>
<body>
    <div class="container-fluid">
        <div class="row">
            <!-- Sidebar -->
            @await Component.InvokeAsync("AdminSidebar")

            <!-- Main content -->
            <main class="col-md-9 ms-sm-auto col-lg-10 px-md-4">
                <div class="d-flex justify-content-between flex-wrap align-items-center pt-3 pb-2 mb-3 border-bottom">
                    <h1 class="h2">Yeni Masa Ekle</h1>
                </div>

                <div class="create-form-card">
                    <h3 class="text-center">🪑 Masa Bilgileri</h3>
                    <form asp-action="Create" asp-controller="Table" asp-area="Admin" method="post">
                        @Html.AntiForgeryToken()
                        <div class="mb-4">
                            <label for="tableNumber" class="form-label fw-bold">Masa Numarası</label>
                            <input type="text" class="form-control form-control-lg" id="tableNumber" name="tableNumber"
                                   placeholder="Örn: 1, A1, VIP-3" required autofocus>
                            <div class="form-text">Her masanın benzersiz bir numarası olmalıdır.</div>
                        </div>
                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-success btn-save">Masayı Kaydet</button>
                            <a asp-action="Index" asp-controller="Table" asp-area="Admin" class="btn btn-outline-secondary btn-back">
                                ← Geri Dön
                            </a>
                        </div>
                    </form>
                </div>
            </main>
        </div>
    </div>

    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>

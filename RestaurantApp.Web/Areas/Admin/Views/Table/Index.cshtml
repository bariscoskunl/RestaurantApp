@model IEnumerable<Table>
@using RestaurantApp.Common.Enums

<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin Panel - Masa Yönetimi</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="~/css/admin.css" rel="stylesheet">
    <style>
        /* ===== Masa Kartları ===== */
        .table-card-link {
            text-decoration: none;
            color: inherit;
            display: block;
        }
        .table-card-link:hover {
            text-decoration: none;
            color: inherit;
        }
        .table-card {
            border-radius: 16px;
            padding: 1.25rem 1rem;
            margin-bottom: 0;
            text-align: center;
            box-shadow: 0 2px 8px rgba(0,0,0,0.1);
            transition: transform 0.15s ease, box-shadow 0.15s ease;
            position: relative;
            min-height: 180px;
            display: flex;
            flex-direction: column;
            justify-content: space-between;
            cursor: pointer;
        }
        .table-card:hover {
            transform: translateY(-3px);
            box-shadow: 0 6px 20px rgba(0,0,0,0.15);
        }

        /* Durum Renkleri */
        .table-card.status-empty {
            background: linear-gradient(135deg, #d4edda 0%, #c3e6cb 100%);
            border: 2px solid #28a745;
        }
        .table-card.status-occupied {
            background: linear-gradient(135deg, #f8d7da 0%, #f5c6cb 100%);
            border: 2px solid #dc3545;
        }
        .table-card.status-waiting {
            background: linear-gradient(135deg, #fff3cd 0%, #ffeeba 100%);
            border: 2px solid #ffc107;
        }

        .table-card .table-number {
            font-size: 1.5rem;
            font-weight: 700;
            margin-bottom: 0.2rem;
        }
        .table-card .table-status-badge {
            font-size: 0.75rem;
            font-weight: 600;
            padding: 0.25rem 0.6rem;
            border-radius: 20px;
            display: inline-block;
            margin-bottom: 0.5rem;
        }
        .badge-empty { background-color: #28a745; color: #fff; }
        .badge-occupied { background-color: #dc3545; color: #fff; }
        .badge-waiting { background-color: #ffc107; color: #212529; }

        /* Kart özet bilgileri */
        .card-summary {
            background: rgba(255,255,255,0.6);
            border-radius: 8px;
            padding: 0.4rem 0.5rem;
            font-size: 0.78rem;
            margin-top: 0.3rem;
        }
        .card-summary .summary-row {
            display: flex;
            justify-content: space-between;
            padding: 0.1rem 0;
        }
        .card-summary .summary-label { color: #555; }
        .card-summary .summary-value { font-weight: 700; }
        .card-summary .summary-total {
            font-size: 0.9rem;
            font-weight: 800;
            border-top: 1px solid #ccc;
            padding-top: 0.2rem;
            margin-top: 0.2rem;
        }

        .card-click-hint {
            font-size: 0.68rem;
            color: #777;
            margin-top: 0.4rem;
        }

        /* Özet kartları */
        .summary-card {
            border-radius: 12px;
            padding: 0.75rem 1rem;
            text-align: center;
            font-weight: 600;
            color: #fff;
            font-size: 0.9rem;
        }
        .summary-card .count {
            font-size: 1.8rem;
            font-weight: 800;
            display: block;
        }

        .btn-add-table {
            border-radius: 12px;
            font-size: 1rem;
            font-weight: 600;
            padding: 0.75rem 1.5rem;
        }

        /* İşlem butonları kart içinde (sil vs) */
        .card-bottom-actions {
            margin-top: 0.4rem;
        }
        .btn-delete-sm {
            font-size: 0.65rem;
            padding: 0.15rem 0.4rem;
            opacity: 0.6;
            border-radius: 6px;
        }
        .btn-delete-sm:hover { opacity: 1; }


    </style>
</head>
<body>
    <div class="container-fluid">
        <div class="row">
            <!-- Sidebar -->
            @await Component.InvokeAsync("AdminSidebar")

            <!-- Main content -->
            <main class="col-md-9 ms-sm-auto col-lg-10 px-md-4">
                <div class="d-flex justify-content-between flex-wrap align-items-center pt-3 pb-2 mb-3 border-bottom">
                    <h1 class="h2">🍽 Masa Yönetimi</h1>
                    @if (User.IsInRole("Admin")) 
                        {
                            <a asp-action="Create" asp-controller="Table" asp-area="Admin" class="btn btn-success btn-add-table">
                                + Yeni Masa Ekle
                            </a>                            
                        }
                    </div>

                @{
                    var tableList = Model?.ToList() ?? new List<Table>();
                    var emptyCount = tableList.Count(t => t.Status == TableStatus.Empty);
                    var occupiedCount = tableList.Count(t => t.Status == TableStatus.Occupied);
                    var waitingCount = tableList.Count(t => t.Status == TableStatus.WaitingForBill);
                }

                <!-- Özet Kartları -->
                
                    <div class="row mb-3 g-2">
                        <div class="col-4">
                            <div class="summary-card" style="background-color: #28a745;">
                                <span class="count">@emptyCount</span>
                                Boş
                            </div>
                        </div>
                        <div class="col-4">
                            <div class="summary-card" style="background-color: #dc3545;">
                                <span class="count">@occupiedCount</span>
                                Dolu
                            </div>
                        </div>
                        <div class="col-4">
                            <div class="summary-card" style="background-color: #ffc107; color: #212529;">
                                <span class="count">@waitingCount</span>
                                Hesap Bekliyor
                            </div>
                        </div>
                    </div>
                


                <!-- Masa Kartları Grid -->
                @if (tableList.Any())
                {
                    <div class="row g-3">
                        @foreach (var table in tableList)
                        {
                            var statusClass = table.Status switch
                            {
                                TableStatus.Empty => "status-empty",
                                TableStatus.Occupied => "status-occupied",
                                TableStatus.WaitingForBill => "status-waiting",
                                _ => "status-empty"
                            };
                            var badgeClass = table.Status switch
                            {
                                TableStatus.Empty => "badge-empty",
                                TableStatus.Occupied => "badge-occupied",
                                TableStatus.WaitingForBill => "badge-waiting",
                                _ => "badge-empty"
                            };
                            var statusText = table.Status switch
                            {
                                TableStatus.Empty => "Boş",
                                TableStatus.Occupied => "Dolu",
                                TableStatus.WaitingForBill => "Hesap Bekliyor",
                                _ => "Bilinmiyor"
                            };

                            var activeOrders = table.Orders?.Where(o => o.Status != OrderStatus.Completed && o.Status != OrderStatus.Cancelled).ToList()
                                ?? new List<RestaurantApp.Common.Models.Order>();
                            var allItems = activeOrders.SelectMany(o => o.OrderItems).ToList();
                            var orderTotal = allItems.Sum(oi => oi.UnitPrice * oi.Quantity);
                            var itemCount = allItems.Sum(oi => oi.Quantity);
                            var earliestOrder = activeOrders.OrderBy(o => o.CreatedAt).FirstOrDefault();

                            <div class="col-6 col-md-4 col-lg-3">
                                <a asp-action="Details" asp-controller="Table" asp-area="Admin" asp-route-id="@table.Id" class="table-card-link">
                                    <div class="table-card @statusClass">
                                        <div>
                                            <div class="table-number">Masa @table.TableNumber</div>
                                            <span class="table-status-badge @badgeClass">@statusText</span>
                                        </div>

                                        @if (table.Status != TableStatus.Empty && allItems.Any())
                                        {
                                            <div class="card-summary">
                                                <div class="summary-row">
                                                    <span class="summary-label">Ürün</span>
                                                    <span class="summary-value">@itemCount adet</span>
                                                </div>
                                                @if (earliestOrder != null)
                                                {
                                                    var duration = DateTime.UtcNow - earliestOrder.CreatedAt;
                                                    var durationText = duration.TotalHours >= 1
                                                        ? $"{(int)duration.TotalHours} sa {duration.Minutes} dk"
                                                        : $"{(int)duration.TotalMinutes} dk";
                                                    <div class="summary-row">
                                                        <span class="summary-label">⏱ Süre</span>
                                                        <span class="summary-value">@durationText</span>
                                                    </div>
                                                }
                                                <div class="summary-row summary-total">
                                                    <span>TOPLAM</span>
                                                    <span>@orderTotal.ToString("N2") ₺</span>
                                                </div>
                                            </div>
                                        }
                                        else if (table.Status != TableStatus.Empty)
                                        {
                                            <div class="card-summary text-center">
                                                <small class="text-muted">Henüz sipariş yok</small>
                                            </div>
                                        }

                                        <div class="card-click-hint">Detaylar için tıklayın →</div>
                                    </div>
                                </a>

                                <!-- Sil butonu (link dışında) -->
                                @if(User.IsInRole("Admin"))
                                {
                                <div class="card-bottom-actions text-center mt-1">
                                    <form asp-action="Delete" asp-controller="Table" asp-area="Admin" method="post" style="display:inline;"
                                          onsubmit="return confirm('Bu masayı silmek istediğinize emin misiniz?');">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@table.Id" />
                                        <button type="submit" class="btn btn-outline-secondary btn-delete-sm" title="Masayı Sil">🗑 Sil</button>
                                    </form>
                                </div>
                                }
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div class="text-center py-5">
                        <p class="text-muted fs-5">Henüz kayıtlı masa bulunmuyor.</p>
                        <a asp-action="Create" asp-controller="Table" asp-area="Admin" class="btn btn-success btn-lg">
                            + İlk Masanı Ekle
                        </a>
                    </div>
                }
            </main>
        </div>
    </div>

    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
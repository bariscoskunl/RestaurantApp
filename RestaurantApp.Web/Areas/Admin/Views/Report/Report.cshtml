@model RestaurantApp.Web.Models.ReportViewModel

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        @TempData["ErrorMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@Model.ReportTitle</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="~/css/admin.css" rel="stylesheet">
    <!-- Font Awesome for Icons -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <style>
        .report-header {
            background-color: #f8f9fa;
            border-radius: 10px;
            padding: 20px;
            box-shadow: 0 4px 6px rgba(0,0,0,0.05);
        }
        .report-actions .btn {
            border-radius: 8px;
            font-weight: 500;
            padding: 10px 20px;
            transition: all 0.2s;
        }
        .report-actions .btn:hover {
            transform: translateY(-2px);
            box-shadow: 0 4px 8px rgba(0,0,0,0.1);
        }
        .table-custom {
            background: white;
            border-radius: 10px;
            overflow: hidden;
            box-shadow: 0 4px 6px rgba(0,0,0,0.05);
        }
        .table-custom th {
            background-color: #212529;
            color: white;
            font-weight: 600;
        }
        .product-list {
            list-style-type: none;
            padding-left: 0;
            margin-bottom: 0;
        }
        .product-list li {
            padding: 5px 0;
            border-bottom: 1px solid #eee;
        }
        .product-list li:last-child {
            border-bottom: none;
        }
    </style>
</head>
<body>
    <div class="container-fluid">
        <div class="row">
            @await Component.InvokeAsync("AdminSidebar")

            <main class="col-md-9 ms-sm-auto col-lg-10 px-md-4 py-4">
                <div class="report-header mb-4 d-flex justify-content-between align-items-center flex-wrap">
                    <div>
                        <h1 class="h2 mb-1 fw-bold text-dark"><i class="fas fa-chart-line me-2 text-primary"></i>@Model.ReportTitle</h1>
                        <p class="text-muted mb-0"><i class="far fa-calendar-alt me-2"></i>@Model.DateRangeText</p>
                    </div>
                    <div class="report-actions d-flex gap-2 mt-3 mt-md-0">
                        <a href="@Url.Action("DailyReport", "Report", new { area = "Admin" })" class="btn btn-outline-primary"><i class="fas fa-calendar-day me-2"></i>Günlük</a>
                        <a href="@Url.Action("WeeklyReport", "Report", new { area = "Admin" })" class="btn btn-outline-primary"><i class="fas fa-calendar-week me-2"></i>Haftalık</a>
                        <a href="@Url.Action("MonthlyReport", "Report", new { area = "Admin" })" class="btn btn-outline-primary"><i class="fas fa-calendar-alt me-2"></i>Aylık</a>
                    </div>
                </div>

                <div class="table-responsive table-custom mb-5">
                    <table class="table table-hover align-middle mb-0">
                        <thead>
                            <tr>
                                <th><i class="far fa-clock me-2"></i>Tarih</th>
                                <th><i class="fas fa-lira-sign me-2"></i>Toplam Tutar</th>
                                <th><i class="fas fa-box-open me-2"></i>Satılan Ürünler Detayı</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if(Model.Sales != null && Model.Sales.Any())
                            {
                                foreach (var sale in Model.Sales)
                                {
                                    <tr>
                                        <td class="fw-bold text-secondary">@sale.SaleDate</td>
                                        <td class="fw-bold text-success">@sale.TotalPrice ₺</td>
                                        <td>
                                            <ul class="product-list">
                                                @foreach (var item in sale.SaleProducts)
                                                {
                                                    <li>
                                                        <span class="fw-bold text-dark">@item.Product.Name</span> 
                                                        <span class="badge bg-info text-dark ms-2">Adet: @item.Quantity</span> 
                                                        <span class="text-muted ms-2">Birim Fiyat: @item.ProductPrice ₺</span> 
                                                        <span class="fw-bold text-primary ms-2">Ara Toplam: @item.ProductTotalPrice ₺</span>
                                                    </li>
                                                }
                                            </ul>
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="3" class="text-center py-4 text-muted">
                                        <i class="fas fa-inbox fa-3x mb-3 d-block"></i>
                                        Bu tarihe ait satış kaydı bulunmamaktadır.
                                    </td>
                                </tr>
                            }
                        </tbody>
                        @if(Model.Sales != null && Model.Sales.Any())
                        {
                            <tfoot>
                                <tr class="table-light">
                                    <td class="text-end fw-bold fs-5"><i class="fas fa-calculator me-2 text-primary"></i>Genel Toplam:</td>
                                    <td class="fw-bold fs-5 text-success">@Model.Sales.Sum(s => s.TotalPrice) ₺</td>
                                    <td></td>
                                </tr>
                            </tfoot>
                        }
                    </table>
                </div>

                <div class="card shadow-sm border-0 report-actions">
                    <div class="card-body">
                        <h5 class="card-title mb-4 fw-bold text-dark"><i class="fas fa-download me-2 text-success"></i>Raporları Dışa Aktar</h5>
                        <div class="d-flex flex-wrap gap-3">
                            <div class="btn-group">
                                <a href="@Url.Action("ExportToExcel", "Report", new { area = "Admin", reportType = "daily" })" class="btn btn-success"><i class="fas fa-file-excel me-2"></i>Günlük Excel</a>
                                <a href="@Url.Action("ExportToExcel", "Report", new { area = "Admin", reportType = "weekly" })" class="btn btn-success"><i class="fas fa-file-excel me-2"></i>Haftalık Excel</a>
                                <a href="@Url.Action("ExportToExcel", "Report", new { area = "Admin", reportType = "monthly" })" class="btn btn-success"><i class="fas fa-file-excel me-2"></i>Aylık Excel</a>
                            </div>
                            <div class="btn-group">
                                <a href="@Url.Action("ExportToPdf", "Report", new { area = "Admin", reportType = "daily" })" class="btn btn-danger"><i class="fas fa-file-pdf me-2"></i>Günlük PDF</a>
                                <a href="@Url.Action("ExportToPdf", "Report", new { area = "Admin", reportType = "weekly" })" class="btn btn-danger"><i class="fas fa-file-pdf me-2"></i>Haftalık PDF</a>
                                <a href="@Url.Action("ExportToPdf", "Report", new { area = "Admin", reportType = "monthly" })" class="btn btn-danger"><i class="fas fa-file-pdf me-2"></i>Aylık PDF</a>
                            </div>
                        </div>
                    </div>
                </div>
            </main>
        </div>
    </div>

    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>